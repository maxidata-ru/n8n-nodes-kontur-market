{
  "name": "n8n-nodes-kontur-market",
  "version": "0.1.11",
  "description": "Нода для интеграции Контур.Маркет с платформой автоматизации n8n. Позволяет получать данные из Маркета о товарах, остатках, продажах, клиентах и акциях, а также управлять товарами и остатками.",
  "license": "MIT",
  "homepage": "https://github.com/maxidata-ru/n8n-nodes-kontur-market",
  "keywords": [
    "n8n-community-node-package"
  ],
  "author": {
    "name": "Ахмадинуров Максим",
    "email": "mahmadinurov@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxidata-ru/n8n-nodes-kontur-market.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate:properties": "node scripts/generate-properties.cjs",
    "build": "n8n-node build",
    "build:from-openapi": "npm run generate:properties && n8n-node build",
    "build:watch": "tsc --watch",
    "dev:clean": "node scripts/reset-dev-env.cjs",
    "dev:reset": "npm run dev:clean && npm run dev",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/KonturMarketApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/KonturMarket/KonturMarket.node.js"
    ]
  },
  "devDependencies": {
    "@devlikeapro/n8n-openapi-node": "^0.1.4",
    "@n8n/node-cli": "*",
    "eslint": "9.32.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
